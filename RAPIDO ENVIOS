        function updateDestinations() {
            const origin = document.getElementById('origin-zone').value;
            const destSelect = document.getElementById('dest-zone');
            const zones = getZones();

            destSelect.innerHTML = '<option value="">Selecciona zona de destino</option>';
            destSelect.disabled = !origin;

            if (origin && zones[origin]) {
                Object.keys(zones[origin].prices).forEach(destKey => {
                    if (destKey !== origin) {
                        const option = document.createElement('option');
                        option.value = destKey;
                        option.textContent = zones[destKey].name + ' - $' + zones[origin].prices[destKey].toLocaleString();
                        destSelect.appendChild(option);
                    }
                });
            }
        }

        function calculatePrice(event) {
            event.preventDefault();
            
            const origin = document.getElementById('origin-zone').value;
            const dest = document.getElementById('dest-zone').value;
            const service = document.getElementById('service-type').value;
            const speed = document.getElementById('speed').value;

            if (!origin || !dest) {
                alert('Por favor selecciona origen y destino');
                return;
            }

            const zones = getZones();
            const basePrice = zones[origin].prices[dest];
            const serviceExtra = SERVICE_EXTRA[service].amount;
            const speedExtra = SPEED_EXTRA[speed].amount;
            const total = basePrice + serviceExtra + speedExtra;

            // Display result
            const resultDiv = document.getElementById('price-result');
            const routeDiv = document.getElementById('price-route');
            const amountDiv = document.getElementById('price-amount');
            const detailDiv = document.getElementById('price-detail');
            const whatsappBtn = document.getElementById('whatsapp-btn');

            routeDiv.textContent = `${zones[origin].name} → ${zones[dest].name}`;
            amountDiv.textContent = '$' + total.toLocaleString() + ' COP';
            
            let details = [];
            if (service !== 'standard') details.push(SERVICE_EXTRA[service].name);
            if (speed !== 'normal') details.push(SPEED_EXTRA[speed].name);
            details.push(`Entrega: ${SPEED_EXTRA[speed].time}`);
            
            detailDiv.textContent = details.join(' | ');

            // Update WhatsApp link with new number
            const message = `Hola Rápido Envíos!%0A%0AQuiero solicitar un envío:%0A• Desde: ${zones[origin].name}%0A• Hasta: ${zones[dest].name}%0A• Servicio: ${SERVICE_EXTRA[service].name}%0A• Velocidad: ${SPEED_EXTRA[speed].name}%0A• Valor: $${total.toLocaleString()}%0A%0AMi dirección exacta de recogida: [ESCRÍBELA AQUÍ]%0AMi dirección exacta de entrega: [ESCRÍBELA AQUÍ]`;
            whatsappBtn.href = `${WHATSAPP_LINK}?text=${message}`;

            resultDiv.classList.add('show');
            resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

